<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" prefWidth="1400" prefHeight="900" styleClass="root-pane">
    <children>
        <VBox alignment="CENTER" spacing="14.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Seller Dashboard" styleClass="title-label"/>
            <Label text="Temporary screen for navigation test" styleClass="subtitle-label"/>
        </VBox>
    </children>
</AnchorPane>