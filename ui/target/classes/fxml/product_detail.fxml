<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.ProductDetailController"
            prefWidth="1400" prefHeight="900"
            styleClass="detail-root">

    <children>
        <BorderPane AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <top>
                <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="top-nav">
                    <padding>
                        <Insets top="18" right="36" bottom="18" left="36"/>
                    </padding>

                    <Label text="BidWave" styleClass="nav-brand"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="Back to Showroom"
                            styleClass="secondary-button"
                            onAction="#handleBack"/>
                </HBox>
            </top>

            <center>
                <HBox spacing="28.0">
                    <padding>
                        <Insets top="30" right="36" bottom="30" left="36"/>
                    </padding>

                    <VBox spacing="16.0" styleClass="detail-image-panel" HBox.hgrow="ALWAYS">
                        <ImageView fx:id="mainImageView"
                                   fitWidth="520"
                                   fitHeight="360"
                                   preserveRatio="true"/>

                        <HBox spacing="14.0">
                            <ImageView fx:id="thumb1ImageView"
                                       fitWidth="150"
                                       fitHeight="100"
                                       preserveRatio="true"/>
                            <ImageView fx:id="thumb2ImageView"
                                       fitWidth="150"
                                       fitHeight="100"
                                       preserveRatio="true"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="16.0" styleClass="detail-info-panel" HBox.hgrow="ALWAYS">
                        <Label fx:id="productNameLabel"
                               text="Product Name"
                               styleClass="detail-title"/>

                        <Label fx:id="currentBidLabel"
                               text="Current Highest Bid"
                               styleClass="detail-meta"/>

                        <Label fx:id="countdownLabel"
                               text="Countdown"
                               styleClass="detail-meta"/>

                        <Label fx:id="statusLabel"
                               text="Status"
                               styleClass="detail-status"/>

                        <Label fx:id="specsLabel"
                               text="Specs"
                               wrapText="true"
                               styleClass="detail-specs"/>

                        <VBox spacing="10.0" styleClass="bid-box">
                            <Label text="Quick Bid (demo)" styleClass="field-label"/>
                            <TextField fx:id="bidAmountField"
                                       promptText="Enter amount, e.g. 15000"/>
                            <Label fx:id="bidMessageLabel"
                                   text=""
                                   styleClass="error-label"/>
                        </VBox>

                        <HBox spacing="14.0">
                            <Button text="Place Bid"
                                    styleClass="primary-button"
                                    onAction="#handlePlaceBid"/>

                            <Button text="Join Live Bidding"
                                    styleClass="secondary-button"
                                    onAction="#handleJoinLiveBidding"/>
                        </HBox>
                    </VBox>
                </HBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>