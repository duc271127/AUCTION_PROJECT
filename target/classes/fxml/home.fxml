<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.HomeController"
            prefWidth="1400" prefHeight="900"
            styleClass="home-root">

    <children>
        <BorderPane AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="0.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">

            <top>
                <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="home-top-nav">
                    <padding>
                        <Insets top="18" right="32" bottom="18" left="32"/>
                    </padding>

                    <Label text="BidWave" styleClass="home-brand"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button text="Login / Register"
                            styleClass="secondary-button"
                            onAction="#handleGoToAuth"/>
                </HBox>
            </top>

            <center>
                <VBox spacing="32.0">
                    <padding>
                        <Insets top="36" right="36" bottom="36" left="36"/>
                    </padding>

                    <VBox spacing="16.0" styleClass="hero-box">
                        <Label text="Bid smarter. Win faster.&#10;Experience premium online auctions."
                               styleClass="home-hero-title"/>
                        <Label text="BidWave brings curated listings, real-time bidding, and trusted seller experiences into one elegant platform."
                               styleClass="home-hero-subtitle"
                               wrapText="true"/>

                        <HBox spacing="14.0">
                            <Button text="Explore Auctions"
                                    styleClass="primary-button"
                                    onAction="#handleGoToShowroom"/>
                            <Button text="Get Started"
                                    styleClass="secondary-button"
                                    onAction="#handleGoToAuth"/>
                        </HBox>
                    </VBox>

                    <HBox spacing="20.0">
                        <VBox spacing="10.0" styleClass="feature-card" HBox.hgrow="ALWAYS">
                            <Label text="Real-time Bidding" styleClass="feature-title"/>
                            <Label text="Jump into live auctions with instant bid updates and responsive navigation."
                                   styleClass="feature-text"
                                   wrapText="true"/>
                        </VBox>

                        <VBox spacing="10.0" styleClass="feature-card" HBox.hgrow="ALWAYS">
                            <Label text="Trusted Sellers" styleClass="feature-title"/>
                            <Label text="Browse verified listings and structured seller dashboards built for clarity."
                                   styleClass="feature-text"
                                   wrapText="true"/>
                        </VBox>

                        <VBox spacing="10.0" styleClass="feature-card" HBox.hgrow="ALWAYS">
                            <Label text="Curated Auctions" styleClass="feature-title"/>
                            <Label text="Discover premium watches, collectibles, luxury goods, and exclusive lots."
                                   styleClass="feature-text"
                                   wrapText="true"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="14.0">
                        <Label text="Featured Highlights" styleClass="section-title"/>

                        <HBox spacing="20.0">
                            <VBox spacing="10.0" styleClass="preview-card" HBox.hgrow="ALWAYS">
                                <Label text="Luxury Watches" styleClass="preview-title"/>
                                <Label text="Explore iconic timepieces with active bids and premium provenance."
                                       styleClass="preview-text"
                                       wrapText="true"/>
                            </VBox>

                            <VBox spacing="10.0" styleClass="preview-card" HBox.hgrow="ALWAYS">
                                <Label text="Fine Art &amp; Decor" styleClass="preview-title"/>
                                <Label text="Browse curated objects, rare collections, and statement pieces."
                                       styleClass="preview-text"
                                       wrapText="true"/>
                            </VBox>

                            <VBox spacing="10.0" styleClass="preview-card" HBox.hgrow="ALWAYS">
                                <Label text="Sports &amp; Memorabilia" styleClass="preview-title"/>
                                <Label text="Find signed jerseys, collectibles, and investment-grade memorabilia."
                                       styleClass="preview-text"
                                       wrapText="true"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>