<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.client.controller.LiveBiddingController"
            prefWidth="1400" prefHeight="900"
            styleClass="root-pane">

    <children>
        <HBox spacing="20.0"
              AnchorPane.topAnchor="20.0"
              AnchorPane.bottomAnchor="20.0"
              AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0">

            <VBox spacing="18.0" HBox.hgrow="ALWAYS" styleClass="page-card">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>

                <Label fx:id="lotTitleLabel" styleClass="live-title"/>

                <HBox spacing="12.0">
                    <Label text="Status:" styleClass="section-label"/>
                    <Label fx:id="connectionStatusLabel" styleClass="connection-badge"/>
                </HBox>

                <VBox spacing="6.0" styleClass="price-box">
                    <Label text="Current Highest Bid" styleClass="section-label"/>
                    <Label fx:id="currentBidLabel" styleClass="current-bid-label"/>
                </VBox>

                <VBox spacing="6.0" styleClass="countdown-box">
                    <Label text="Countdown" styleClass="section-label"/>
                    <Label fx:id="countdownLabel" styleClass="countdown-label"/>
                </VBox>

                <Label fx:id="outbidAlertLabel" text="" styleClass="live-alert"/>

                <VBox spacing="8.0">
                    <Label text="Enter Your Bid" styleClass="section-label"/>
                    <TextField fx:id="bidInputField" promptText="Enter bid amount"/>
                </VBox>

                <HBox spacing="10.0">
                    <Button text="+500" styleClass="secondary-button" onAction="#handleAdd500"/>
                    <Button text="+1k" styleClass="secondary-button" onAction="#handleAdd1000"/>
                    <Button text="+5k" styleClass="secondary-button" onAction="#handleAdd5000"/>
                </HBox>

                <Button text="Place Bid"
                        maxWidth="Infinity"
                        styleClass="primary-button"
                        onAction="#handlePlaceBid"/>

                <Button text="Back to Detail"
                        maxWidth="Infinity"
                        styleClass="secondary-button"
                        onAction="#handleBack"/>
            </VBox>

            <VBox spacing="16.0" prefWidth="420.0" styleClass="page-card">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>

                <Label text="Bid History" styleClass="panel-title"/>
                <ListView fx:id="bidHistoryListView" VBox.vgrow="ALWAYS"/>
            </VBox>

        </HBox>
    </children>
</AnchorPane>